# Primary LLM provider — Gemini via Google's OpenAI-compatible endpoint.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model (default: gemini-3.1-pro-preview — paid tier).
# For free-tier testing use: gemini-2.5-flash
# MEDBOARD_MODEL=gemini-3.1-pro-preview

# Optional: flip provider to OpenAI (requires OPENAI_API_KEY below)
# MEDBOARD_PROVIDER=openai
# OPENAI_API_KEY=

# Optional: NCBI Entrez credentials (raises rate limit from 3 to 10 req/s)
# NCBI_EMAIL=
# NCBI_API_KEY=

# Optional: Brave Search (enables the `web_search` tool for all agents).
# Free tier 2k queries/mo at https://brave.com/search/api/
# Brave_API=
