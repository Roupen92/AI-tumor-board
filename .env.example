OPENAI_API_KEY=
# Optional: override the model (default: gpt-5.1)
# MEDBOARD_MODEL=gpt-5.1

# Optional: NCBI Entrez credentials (raises rate limit from 3 to 10 req/s)
# NCBI_EMAIL=
# NCBI_API_KEY=

# Optional: Brave Search (enables the `web_search` tool for all agents).
# Free tier 2k queries/mo at https://brave.com/search/api/
# Brave_API=

# Optional: OncoKB (enables `oncokb_query` for the molecular oncologist).
# Free for academic use; request at https://www.oncokb.org/apiAccess
# ONCOKB_API_KEY=
